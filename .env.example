# HMAC signing secret for API authentication
HMAC_SECRET=your-secret-key-here-change-in-production

# Vercel KV (Redis) credentials
KV_REST_API_URL=https://your-kv.vercel-storage.com
KV_REST_API_TOKEN=your-kv-token-here

# CORS - comma-separated list of allowed origins for embed/API
ALLOWED_ORIGINS=https://oceantarkari.com,https://admin.oceantarkari.com

# Optional: OpenRouteService API key (alternative to OSRM)
ORS_API_KEY=

# Bias Nominatim geocoding (ISO 3166-1 alpha2, comma-separated). Example: np
NOMINATIM_COUNTRY_CODES=
# Same value for the planner (client) search bias; optional but recommended
NEXT_PUBLIC_NOMINATIM_COUNTRY_CODES=

# Site URL for absolute links
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# Google Maps API key for embed links (optional)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ElevenLabs API key for voice alerts
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# Used client-side for planner HMAC signing (set same as HMAC_SECRET for dev)
# WARNING: In production, implement a server-side signing endpoint instead
NEXT_PUBLIC_HMAC_SECRET=dev-secret-replace-for-production
